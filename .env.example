# .env.example — 複製此檔為 .env 並填入真實值，請勿將 .env 上傳至版本控制

# Flask 應用程式的加密金鑰（用於 Session 簽署），請使用足夠長的隨機字串
SECRET_KEY=your-very-secret-key-here

# Flask 執行環境：development / production
FLASK_ENV=development

# PostgreSQL 連線字串
# 格式：postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/event_registration
